rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // 0. Global Safety Net
    match /{document=**} {
      allow read, write: if false;
    }

    // --- Helpers ---
    function isSignedIn() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    function isValidId(id) {
      return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$');
    }

    function incoming() {
      return request.resource.data;
    }

    function existing() {
      return resource.data;
    }

    // --- User Profiles ---
    match /users/{userId} {
      allow get: if isOwner(userId);
      allow list: if isSignedIn() && resource.data.uid == request.auth.uid;
      allow create: if isOwner(userId) && isValidUser(incoming());
      allow update: if isOwner(userId) && isValidUser(incoming()) 
        && incoming().diff(existing()).affectedKeys().hasOnly([
          'businessName', 'displayName', 'directorName', 'qrisPayload', 
          'autoGeneratePdfLedger', 'thermalPrinterOptimization'
        ])
        && incoming().uid == existing().uid
        && incoming().email == existing().email
        && incoming().createdAt == existing().createdAt;

      function isValidUser(data) {
        return data.keys().hasAll(['email', 'displayName', 'createdAt', 'uid'])
          && data.email is string && data.email.size() <= 200
          && data.displayName is string && data.displayName.size() <= 200
          && data.uid == request.auth.uid
          && (data.get('businessName', '') is string && data.get('businessName', '').size() <= 200)
          && (data.get('directorName', '') is string && data.get('directorName', '').size() <= 200)
          && (data.get('qrisPayload', '') is string && data.get('qrisPayload', '').size() <= 6000)
          && (data.get('autoGeneratePdfLedger', false) is bool)
          && (data.get('thermalPrinterOptimization', false) is bool)
          && (request.method == 'create' ? data.createdAt == request.time : true);
      }
    }

    // --- Transactions ---
    match /transactions/{transactionId} {
      allow list: if isSignedIn() && resource.data.userId == request.auth.uid;
      allow get: if isSignedIn() && resource.data.userId == request.auth.uid;
      
      allow create: if isSignedIn() && incoming().userId == request.auth.uid && isValidTransaction(incoming());
      
      allow update: if isSignedIn() && existing().userId == request.auth.uid && incoming().userId == request.auth.uid 
        && isValidTransaction(incoming());

      allow delete: if isSignedIn() && existing().userId == request.auth.uid;

      function isValidTransaction(t) {
        return (t.get('userId', '') == request.auth.uid)
          && (t.get('type', '') in ['income', 'expense'])
          && (t.get('category', '') is string && t.get('category', '').size() <= 100)
          && (t.get('amount', 0) is number && t.get('amount', 0) >= 0)
          && (t.get('date', '') is string)
          && (t.get('createdAt', request.time) is timestamp)
          && (t.get('description', '') is string && t.get('description', '').size() <= 1000)
          && (t.get('customerName', '') is string && t.get('customerName', '').size() <= 200)
          && (t.get('paymentMethod', 'cash') in ['cash', 'qris', 'credit'])
          && (t.get('productName', '') is string && t.get('productName', '').size() <= 200)
          && (t.get('hpp', 0) is number)
          && (t.get('invoiceNo', '') is string)
          && (t.get('updatedAt', request.time) is timestamp);
      }
    }

    // --- Products ---
    match /products/{productId} {
      allow list: if isSignedIn() && resource.data.userId == request.auth.uid;
      allow get: if isSignedIn() && resource.data.userId == request.auth.uid;

      allow create: if isSignedIn() && incoming().userId == request.auth.uid && isValidProduct(incoming());
      allow update: if isSignedIn() && existing().userId == request.auth.uid && incoming().userId == request.auth.uid 
        && isValidProduct(incoming());
      allow delete: if isSignedIn() && existing().userId == request.auth.uid;

      function isValidProduct(p) {
        return (p.get('userId', '') == request.auth.uid)
          && (p.get('name', '') is string && p.get('name', '').size() <= 200)
          && (p.get('price', 0) is number && p.get('price', 0) >= 0)
          && (p.get('hpp', 0) is number && p.get('hpp', 0) >= 0)
          && (p.get('stock', 0) is number)
          && (p.get('createdAt', request.time) is timestamp);
      }
    }

    // --- Debts ---
    match /debts/{debtId} {
      allow list: if isSignedIn() && resource.data.userId == request.auth.uid;
      allow get: if isSignedIn() && resource.data.userId == request.auth.uid;

      allow create: if isSignedIn() && incoming().userId == request.auth.uid && isValidDebt(incoming());
      allow update: if isSignedIn() && existing().userId == request.auth.uid && incoming().userId == request.auth.uid 
        && isValidDebt(incoming());
      allow delete: if isSignedIn() && existing().userId == request.auth.uid;

      function isValidDebt(d) {
        return (d.get('userId', '') == request.auth.uid)
          && (d.get('type', '') in ['payable', 'receivable'])
          && (d.get('contactName', '') is string && d.get('contactName', '').size() <= 200)
          && (d.get('totalAmount', 0) is number && d.get('totalAmount', 0) >= 0)
          && (d.get('remainingAmount', 0) is number && d.get('remainingAmount', 0) >= 0)
          && (d.get('status', 'pending') in ['pending', 'partially_paid', 'paid'])
          && (d.get('createdAt', request.time) is timestamp)
          && (d.get('updatedAt', request.time) is timestamp);
      }
    }

    // --- Tax Checklist ---
    match /taxChecklist/{userId} {
      allow read, write: if isOwner(userId);
    }

  }
}
