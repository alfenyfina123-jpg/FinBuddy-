rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // 0. Global Safety Net
    match /{document=**} {
      allow read, write: if false;
    }

    // --- Helpers ---
    function isSignedIn() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    function isValidId(id) {
      return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$');
    }

    function incoming() {
      return request.resource.data;
    }

    function existing() {
      return resource.data;
    }

    // --- User Profiles ---
    match /users/{userId} {
      allow get: if isOwner(userId);
      allow list: if isSignedIn() && resource.data.uid == request.auth.uid;
      allow create: if isOwner(userId) && isValidUser(incoming());
      allow update: if isOwner(userId) && isValidUser(incoming()) 
        && incoming().diff(existing()).affectedKeys().hasOnly([
          'businessName', 'displayName', 'directorName', 'qrisPayload', 
          'autoGeneratePdfLedger', 'thermalPrinterOptimization'
        ])
        && incoming().uid == existing().uid
        && incoming().email == existing().email
        && incoming().createdAt == existing().createdAt;

      function isValidUser(data) {
        return data.keys().hasAll(['email', 'displayName', 'createdAt', 'uid'])
          && data.email is string && data.email.size() <= 200
          && data.displayName is string && data.displayName.size() <= 200
          && data.uid == request.auth.uid
          && (data.get('businessName', '') is string && data.get('businessName', '').size() <= 200)
          && (data.get('directorName', '') is string && data.get('directorName', '').size() <= 200)
          && (data.get('qrisPayload', '') is string && data.get('qrisPayload', '').size() <= 6000)
          && (data.get('autoGeneratePdfLedger', false) is bool)
          && (data.get('thermalPrinterOptimization', false) is bool)
          && (request.method == 'create' ? data.createdAt == request.time : true);
      }
    }

    // --- Transactions ---
    match /transactions/{transactionId} {
      allow list: if isSignedIn() && resource.data.userId == request.auth.uid;
      allow get: if isSignedIn() && resource.data.userId == request.auth.uid;
      
      allow create: if isSignedIn() && incoming().userId == request.auth.uid && isValidTransaction(incoming());
      
      allow update: if isSignedIn() && existing().userId == request.auth.uid && incoming().userId == request.auth.uid 
        && isValidTransaction(incoming());

      allow delete: if isSignedIn() && existing().userId == request.auth.uid;

      function isValidTransaction(t) {
        return t.keys().hasAll(['userId', 'type', 'category', 'amount', 'date', 'createdAt'])
          && t.userId == request.auth.uid
          && t.type in ['income', 'expense']
          && t.category is string && t.category.size() <= 100
          && t.amount is number && t.amount >= 0
          && t.date is string && t.date.size() <= 20
          && (t.get('description', '') is string && t.get('description', '').size() <= 1000)
          && (t.get('customerName', '') is string && t.get('customerName', '').size() <= 200)
          && (t.get('paymentMethod', 'cash') in ['cash', 'qris', 'credit'])
          && (t.get('productName', '') is string && t.get('productName', '').size() <= 200)
          && (t.get('hpp', 0) is number)
          && (request.method == 'create' ? t.createdAt == request.time : true);
      }
    }

    // --- Products ---
    match /products/{productId} {
      allow list: if isSignedIn() && resource.data.userId == request.auth.uid;
      allow get: if isSignedIn() && resource.data.userId == request.auth.uid;

      allow create: if isSignedIn() && incoming().userId == request.auth.uid && isValidProduct(incoming());
      allow update: if isSignedIn() && existing().userId == request.auth.uid && incoming().userId == request.auth.uid 
        && isValidProduct(incoming());
      allow delete: if isSignedIn() && existing().userId == request.auth.uid;

      function isValidProduct(p) {
        return p.keys().hasAll(['userId', 'name', 'price', 'hpp', 'stock', 'createdAt'])
          && p.userId == request.auth.uid
          && p.name is string && p.name.size() <= 200
          && (p.get('code', '') is string && p.get('code', '').size() <= 100)
          && (p.get('category', '') is string && p.get('category', '').size() <= 100)
          && p.price is number && p.price >= 0
          && p.hpp is number && p.hpp >= 0
          && p.stock is number
          && (p.get('unit', 'pcs') is string && p.get('unit', 'pcs').size() <= 50)
          && (request.method == 'create' ? p.createdAt == request.time : true);
      }
    }

    // --- Debts ---
    match /debts/{debtId} {
      allow list: if isSignedIn() && resource.data.userId == request.auth.uid;
      allow get: if isSignedIn() && resource.data.userId == request.auth.uid;

      allow create: if isSignedIn() && incoming().userId == request.auth.uid && isValidDebt(incoming());
      allow update: if isSignedIn() && existing().userId == request.auth.uid && incoming().userId == request.auth.uid 
        && isValidDebt(incoming());
      allow delete: if isSignedIn() && existing().userId == request.auth.uid;

      function isValidDebt(d) {
        return d.keys().hasAll(['userId', 'type', 'contactName', 'totalAmount', 'remainingAmount', 'status', 'createdAt'])
          && d.userId == request.auth.uid
          && (d.get('transactionId', '') is string)
          && d.type in ['payable', 'receivable']
          && d.contactName is string && d.contactName.size() <= 200
          && d.totalAmount is number && d.totalAmount >= 0
          && d.remainingAmount is number && d.remainingAmount >= 0
          && d.status in ['pending', 'partially_paid', 'paid']
          && (d.get('dueDate', '') is string)
          && (d.get('notes', '') is string)
          && (request.method == 'create' ? d.createdAt == request.time : true);
      }
    }

    // --- Tax Checklist ---
    match /taxChecklist/{userId} {
      allow read, write: if isOwner(userId);
    }

  }
}
